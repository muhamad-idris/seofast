{
  "manifest_version": 3,
  "name": "SeoFast Auto Clicker",
  "version": "1.0",
  "description": "Otomatisasi tugas klik pada situs SeoFast.",
  "icons": {
    "48": "icons/icon.svg"
  },
  "action": {
    "default_icon": "icons/icon.svg",
    "default_title": "Buka Popup",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["scripts/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["scripts/content.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "seofast-autoclicker@tamsis.xd",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
