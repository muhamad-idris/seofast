{
  "manifest_version": 3,
  "name": "Template Ekstensi Firefox",
  "version": "1.0",
  "description": "Template dasar untuk ekstensi Firefox (Manifest V3).",
  "icons": {
    "48": "icons/icon-48.png"
  },
  "action": {
    "default_icon": "icons/icon-48.png",
    "default_title": "Buka Popup",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["scripts/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["scripts/content.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "template@example.com",
      "strict_min_version": "109.0"
    }
  }
}
